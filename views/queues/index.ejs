<div class="page-header">
  <div class="page-header-left">
    <h1 class="page-title">Filas de Atendimento</h1>
    <p class="page-subtitle"><%= queues.length %> filas configuradas</p>
  </div>
  <div class="page-header-right">
    <a href="/queues/create" class="btn btn-primary">
      <i class="fas fa-plus"></i> Nova Fila
    </a>
  </div>
</div>

<div class="queues-grid">
  <% queues.forEach(queue => { %>
  <div class="queue-card" style="border-top-color: <%= queue.color %>">
    <div class="qc-header">
      <div class="qc-icon" style="background: <%= queue.color %>20; color: <%= queue.color %>">
        <%= queue.icon %>
      </div>
      <div class="qc-info">
        <h3 class="qc-name"><%= queue.name %></h3>
        <p class="qc-desc"><%= queue.description || 'Sem descrição' %></p>
      </div>
      <div class="qc-actions">
        <% if (!queue.isActive) { %>
        <span class="badge badge-secondary">Inativa</span>
        <% } %>
        <a href="/queues/<%= queue._id %>/edit" class="btn-icon" title="Editar">
          <i class="fas fa-edit"></i>
        </a>
      </div>
    </div>

    <!-- SLA Info -->
    <% if (queue.sla) { %>
    <div class="qc-sla">
      <span class="badge badge-<%= queue.sla.priorityBadge %>">
        <%= queue.sla.priorityIcon %> SLA <%= queue.sla.priorityDisplay %>
      </span>
      <span class="sla-times">
        Resposta: <%= queue.sla.responseTime.hours %>h <%= queue.sla.responseTime.minutes > 0 ? queue.sla.responseTime.minutes + 'm' : '' %>
        | Resolução: <%= queue.sla.resolutionTime.hours %>h
      </span>
    </div>
    <% } %>

    <!-- Ticket Counts -->
    <div class="qc-stats">
      <div class="qcs-item qcs-open">
        <span class="qcs-number"><%= queue.ticketCounts ? queue.ticketCounts.open : 0 %></span>
        <span class="qcs-label">Abertos</span>
      </div>
      <div class="qcs-item qcs-progress">
        <span class="qcs-number"><%= queue.ticketCounts ? queue.ticketCounts.inProgress : 0 %></span>
        <span class="qcs-label">Em Progresso</span>
      </div>
      <div class="qcs-item qcs-resolved">
        <span class="qcs-number"><%= queue.ticketCounts ? queue.ticketCounts.resolved : 0 %></span>
        <span class="qcs-label">Resolvidos</span>
      </div>
      <% if (queue.ticketCounts && queue.ticketCounts.breached > 0) { %>
      <div class="qcs-item qcs-breached">
        <span class="qcs-number text-danger"><%= queue.ticketCounts.breached %></span>
        <span class="qcs-label text-danger">SLA Violado</span>
      </div>
      <% } %>
    </div>

    <!-- Agents -->
    <div class="qc-agents">
      <span class="qca-label">Agentes:</span>
      <% if (queue.agents && queue.agents.length > 0) { %>
        <div class="agent-avatars">
          <% queue.agents.slice(0, 4).forEach(agent => { %>
          <div class="user-avatar-xs" title="<%= agent.name %>"><%= agent.name.charAt(0) %></div>
          <% }) %>
          <% if (queue.agents.length > 4) { %>
          <div class="user-avatar-xs avatar-more">+<%= queue.agents.length - 4 %></div>
          <% } %>
        </div>
        <span class="agent-count"><%= queue.agents.length %> agente<%= queue.agents.length !== 1 ? 's' : '' %></span>
      <% } else { %>
        <span class="no-agents">Nenhum agente</span>
      <% } %>
    </div>

    <!-- Auto-assign badge -->
    <% if (queue.autoAssign && queue.autoAssign.enabled) { %>
    <div class="qc-auto">
      <span class="auto-badge">
        <i class="fas fa-robot"></i> Auto-atribuição: <%= queue.autoAssign.method %>
      </span>
    </div>
    <% } %>

    <div class="qc-footer">
      <a href="/tickets?queue=<%= queue._id %>" class="btn btn-ghost btn-sm">
        <i class="fas fa-ticket-alt"></i> Ver Chamados
      </a>
      <a href="/queues/<%= queue._id %>/edit" class="btn btn-secondary btn-sm">
        <i class="fas fa-edit"></i> Editar
      </a>
      <% if (!queue.ticketCounts || (queue.ticketCounts.open + queue.ticketCounts.inProgress + queue.ticketCounts.resolved) === 0) { %>
      <form action="/queues/<%= queue._id %>?_method=DELETE" method="POST" style="display:inline"
            onsubmit="return confirm('Excluir fila <%= queue.name %>?')">
        <button type="submit" class="btn btn-danger btn-sm">
          <i class="fas fa-trash"></i>
        </button>
      </form>
      <% } %>
    </div>
  </div>
  <% }) %>

  <% if (queues.length === 0) { %>
  <div class="empty-state full-width">
    <div class="empty-icon"><i class="fas fa-layer-group"></i></div>
    <h3>Nenhuma fila configurada</h3>
    <p>Crie sua primeira fila de atendimento</p>
    <a href="/queues/create" class="btn btn-primary">
      <i class="fas fa-plus"></i> Criar primeira fila
    </a>
  </div>
  <% } %>
</div>
