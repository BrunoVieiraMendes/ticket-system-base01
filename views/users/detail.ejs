<div class="page-header">
  <div class="page-header-left">
    <a href="/users" class="back-link"><i class="fas fa-arrow-left"></i> Usuários</a>
    <h1 class="page-title"><%= profileUser.name %></h1>
  </div>
</div>

<div class="profile-layout">
  <div class="profile-sidebar">
    <div class="profile-card">
      <div class="profile-avatar" style="background: <%= profileUser.role === 'admin' ? '#ef4444' : profileUser.role === 'agent' ? '#6366f1' : '#22c55e' %>">
        <%= profileUser.initials %>
      </div>
      <h2 class="profile-name"><%= profileUser.name %></h2>
      <p class="profile-email"><%= profileUser.email %></p>
      <span class="badge badge-<%= profileUser.roleBadgeColor %> profile-role"><%= profileUser.roleDisplay %></span>
      <% if (!profileUser.isActive) { %><span class="badge badge-secondary mt-8">Conta inativa</span><% } %>
      <% if (profileUser.phone) { %><p class="profile-phone"><i class="fas fa-phone"></i> <%= profileUser.phone %></p><% } %>
      <% if (profileUser.company) { %><p class="profile-phone"><i class="fas fa-building"></i> <%= profileUser.company %></p><% } %>
    </div>
  </div>

  <div class="profile-main">
    <div class="form-card">
      <form action="/users/<%= profileUser._id %>?_method=PUT" method="POST">
        <div class="form-section">
          <h3 class="form-section-title"><i class="fas fa-user-cog"></i> Editar Usuário</h3>
          <div class="form-row">
            <div class="form-group">
              <label>Nome</label>
              <input type="text" name="name" class="form-control" value="<%= profileUser.name %>" required>
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" name="email" class="form-control" value="<%= profileUser.email %>" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Perfil</label>
              <select name="role" class="form-control">
                <option value="client" <%= profileUser.role === 'client' ? 'selected' : '' %>>👤 Cliente</option>
                <option value="agent" <%= profileUser.role === 'agent' ? 'selected' : '' %>>🎧 Agente</option>
                <option value="admin" <%= profileUser.role === 'admin' ? 'selected' : '' %>>👑 Admin</option>
              </select>
            </div>
            <div class="form-group">
              <label>Departamento</label>
              <input type="text" name="department" class="form-control" value="<%= profileUser.department || '' %>">
            </div>
          </div>
          <div class="form-group">
            <label>Empresa</label>
            <input type="text" name="company" class="form-control" value="<%= profileUser.company || '' %>">
          </div>

          <div class="form-group">
            <label>Filas atribuídas</label>
            <div class="agents-checkbox-grid">
              <% queues.forEach(q => { %>
              <label class="agent-checkbox">
                <input type="checkbox" name="queueIds" value="<%= q._id %>"
                  <%= profileUser.queues && profileUser.queues.some(uq => uq._id ? uq._id.toString() === q._id.toString() : uq.toString() === q._id.toString()) ? 'checked' : '' %>>
                <div class="acb-content">
                  <span><%= q.icon %></span>
                  <span class="acb-name"><%= q.name %></span>
                </div>
              </label>
              <% }) %>
            </div>
          </div>

          <div class="toggle-row">
            <label class="toggle-label">
              <input type="checkbox" name="isActive" class="toggle-input" <%= profileUser.isActive ? 'checked' : '' %>>
              <span class="toggle-switch"></span>
              Conta ativa
            </label>
          </div>
        </div>

        <div class="form-actions">
          <% if (profileUser._id.toString() !== user._id.toString()) { %>
          <form action="/users/<%= profileUser._id %>?_method=DELETE" method="POST" style="display:inline"
                onsubmit="return confirm('Excluir usuário <%= profileUser.name %>? Esta ação não pode ser desfeita.')">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Excluir</button>
          </form>
          <% } %>
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvar</button>
        </div>
      </form>
    </div>

    <% if (assignedTickets.length > 0) { %>
    <div class="table-card mt-24">
      <div class="card-header"><h3><i class="fas fa-ticket-alt"></i> Chamados Atribuídos</h3></div>
      <table class="data-table">
        <thead><tr><th>Número</th><th>Título</th><th>Status</th><th>Fila</th><th></th></tr></thead>
        <tbody>
          <% assignedTickets.forEach(t => { %>
          <tr>
            <td><span class="ticket-number"><%= t.ticketNumber %></span></td>
            <td><%= t.title.substring(0,40) %></td>
            <td><span class="badge badge-<%= t.statusBadge %>"><%= t.statusDisplay %></span></td>
            <td><%= t.queue ? t.queue.name : '—' %></td>
            <td><a href="/tickets/<%= t._id %>" class="btn-icon"><i class="fas fa-eye"></i></a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
