<div class="ticket-detail-header">
  <div class="tdh-left">
    <a href="/tickets" class="back-link"><i class="fas fa-arrow-left"></i> Chamados</a>
    <div class="ticket-title-row">
      <span class="ticket-num-lg"><%= ticket.ticketNumber %></span>
      <h1 class="ticket-title-lg"><%= ticket.title %></h1>
    </div>
    <div class="ticket-meta-row">
      <span class="badge badge-<%= ticket.statusBadge %>"><%= ticket.statusDisplay %></span>
      <span class="priority-badge priority-<%= ticket.priority %>"><%= ticket.priorityIcon %> <%= ticket.priorityDisplay %></span>
      <% if (ticket.queue) { %>
      <span class="queue-pill" style="border-color: <%= ticket.queue.color %>; color: <%= ticket.queue.color %>">
        <%= ticket.queue.icon %> <%= ticket.queue.name %>
      </span>
      <% } %>
      <span class="sla-badge sla-<%= ticket.slaStatus %>">SLA: <%= ticket.slaStatusDisplay %></span>
    </div>
  </div>
  <div class="tdh-right">
    <% if (['resolved', 'closed'].includes(ticket.status) && user._id.toString() === ticket.createdBy._id.toString() && !ticket.rating) { %>
    <button class="btn btn-primary" onclick="document.getElementById('rateModal').style.display='flex'">
      <i class="fas fa-star"></i> Avaliar
    </button>
    <% } %>
  </div>
</div>

<div class="ticket-layout">
  <!-- Main Content -->
  <div class="ticket-main">

    <!-- Description -->
    <div class="ticket-card">
      <div class="tc-header">
        <div class="tc-author">
          <div class="user-avatar-sm" style="background: <%= ticket.createdBy.role === 'admin' ? '#ef4444' : ticket.createdBy.role === 'agent' ? '#6366f1' : '#22c55e' %>">
            <%= ticket.createdBy.name.charAt(0) %>
          </div>
          <div>
            <strong><%= ticket.createdBy.name %></strong>
            <small>Criou este chamado — <%= new Date(ticket.createdAt).toLocaleDateString('pt-BR', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></small>
          </div>
        </div>
        <span class="tc-label">Descrição Original</span>
      </div>
      <div class="tc-body">
        <p class="ticket-description"><%= ticket.description %></p>
        <% if (ticket.category) { %>
        <div class="tc-tags">
          <span class="category-tag"><i class="fas fa-tag"></i> <%= ticket.category %></span>
          <% (ticket.tags || []).forEach(tag => { %>
          <span class="tag"><%= tag %></span>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Comments -->
    <% comments.forEach(comment => { %>
    <div class="ticket-card <%= comment.type === 'internal' ? 'tc-internal' : '' %>">
      <div class="tc-header">
        <div class="tc-author">
          <div class="user-avatar-sm" style="background: <%= comment.author.role === 'admin' ? '#ef4444' : comment.author.role === 'agent' ? '#6366f1' : '#22c55e' %>">
            <%= comment.author.name.charAt(0) %>
          </div>
          <div>
            <strong><%= comment.author.name %></strong>
            <small><%= comment.timeAgo %></small>
          </div>
        </div>
        <% if (comment.type === 'internal') { %>
        <span class="internal-badge"><i class="fas fa-lock"></i> Nota Interna</span>
        <% } %>
      </div>
      <div class="tc-body">
        <p><%= comment.content %></p>
      </div>
    </div>
    <% }) %>

    <!-- Reply Box -->
    <% if (!['closed', 'cancelled'].includes(ticket.status)) { %>
    <div class="reply-box">
      <div class="reply-header">
        <h3>
          <% if (user.role === 'client') { %>
          <i class="fas fa-reply"></i> Adicionar resposta
          <% } else { %>
          <i class="fas fa-reply"></i> Responder
          <% } %>
        </h3>
        <% if (user.role !== 'client') { %>
        <div class="reply-type-toggle">
          <button class="rtt-btn active" id="publicBtn" onclick="setReplyType('public')">
            <i class="fas fa-globe"></i> Público
          </button>
          <button class="rtt-btn" id="internalBtn" onclick="setReplyType('internal')">
            <i class="fas fa-lock"></i> Interno
          </button>
        </div>
        <% } %>
      </div>
      <form action="/tickets/<%= ticket._id %>/comments" method="POST">
        <input type="hidden" name="type" id="commentType" value="public">
        <textarea name="content" class="reply-textarea" placeholder="Digite sua resposta..." required rows="4"></textarea>
        <div class="reply-footer">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Enviar
          </button>
        </div>
      </form>
    </div>
    <% } %>
  </div>

  <!-- Sidebar -->
  <div class="ticket-sidebar">

    <!-- SLA Widget -->
    <% if (ticket.slaDeadlines && ticket.slaDeadlines.resolutionDeadline) { %>
    <div class="ts-card sla-widget">
      <h4><i class="fas fa-stopwatch"></i> SLA</h4>
      <div class="sla-progress-bar">
        <div class="sla-progress-fill sla-fill-<%= ticket.slaStatus %>"
             style="width: <%= slaProgress %>%"></div>
      </div>
      <div class="sla-info-row">
        <span class="sla-percent <%= ticket.slaStatus %>-text"><%= slaProgress %>% usado</span>
        <% if (slaTimeLeft) { %>
          <% if (slaTimeLeft.expired) { %>
          <span class="sla-time breached-text">Prazo expirado</span>
          <% } else { %>
          <span class="sla-time">Resta <%= slaTimeLeft.hours %>h <%= slaTimeLeft.minutes %>m</span>
          <% } %>
        <% } %>
      </div>
      <div class="sla-deadlines">
        <div class="sla-deadline-item">
          <span class="sdl-label">Resposta:</span>
          <span class="sdl-value <%= ticket.slaDeadlines.responseAchieved ? 'achieved' : '' %>">
            <% if (ticket.slaDeadlines.responseAchieved) { %>
            <i class="fas fa-check-circle text-success"></i>
            <% } %>
            <%= new Date(ticket.slaDeadlines.responseDeadline).toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) %>
          </span>
        </div>
        <div class="sla-deadline-item">
          <span class="sdl-label">Resolução:</span>
          <span class="sdl-value">
            <%= new Date(ticket.slaDeadlines.resolutionDeadline).toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) %>
          </span>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Actions -->
    <% if (user.role !== 'client') { %>
    <div class="ts-card">
      <h4><i class="fas fa-tasks"></i> Ações</h4>

      <!-- Change Status -->
      <div class="action-group">
        <label>Status</label>
        <form action="/tickets/<%= ticket._id %>/status?_method=PUT" method="POST">
          <select name="status" class="form-control" onchange="this.form.submit()">
            <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Aberto</option>
            <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>Em Progresso</option>
            <option value="waiting" <%= ticket.status === 'waiting' ? 'selected' : '' %>>Aguardando</option>
            <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Resolvido</option>
            <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>Fechado</option>
          </select>
        </form>
      </div>

      <!-- Change Priority -->
      <div class="action-group">
        <label>Prioridade</label>
        <form action="/tickets/<%= ticket._id %>/priority?_method=PUT" method="POST">
          <select name="priority" class="form-control" onchange="this.form.submit()">
            <option value="low" <%= ticket.priority === 'low' ? 'selected' : '' %>>🟢 Baixa</option>
            <option value="medium" <%= ticket.priority === 'medium' ? 'selected' : '' %>>🟡 Média</option>
            <option value="high" <%= ticket.priority === 'high' ? 'selected' : '' %>>🔴 Alta</option>
            <option value="critical" <%= ticket.priority === 'critical' ? 'selected' : '' %>>⚫ Crítica</option>
          </select>
        </form>
      </div>

      <!-- Assign Agent -->
      <div class="action-group">
        <label>Responsável</label>
        <form action="/tickets/<%= ticket._id %>/assign?_method=PUT" method="POST">
          <select name="agentId" class="form-control" onchange="this.form.submit()">
            <option value="">Não atribuído</option>
            <% availableAgents.forEach(agent => { %>
            <option value="<%= agent._id %>" <%= ticket.assignedTo && ticket.assignedTo._id.toString() === agent._id.toString() ? 'selected' : '' %>>
              <%= agent.name %>
            </option>
            <% }) %>
          </select>
        </form>
      </div>
    </div>
    <% } %>

    <!-- Client can change status if waiting -->
    <% if (user.role === 'client' && ticket.status === 'waiting') { %>
    <div class="ts-card">
      <h4><i class="fas fa-tasks"></i> Ações</h4>
      <form action="/tickets/<%= ticket._id %>/status?_method=PUT" method="POST">
        <input type="hidden" name="status" value="open">
        <button type="submit" class="btn btn-primary btn-full">
          <i class="fas fa-redo"></i> Reabrir chamado
        </button>
      </form>
    </div>
    <% } %>

    <!-- Ticket Info -->
    <div class="ts-card">
      <h4><i class="fas fa-info-circle"></i> Informações</h4>
      <div class="info-list">
        <div class="info-item">
          <span class="info-label">Aberto por</span>
          <div class="info-value">
            <div class="user-avatar-xs"><%= ticket.createdBy.name.charAt(0) %></div>
            <span><%= ticket.createdBy.name %></span>
          </div>
        </div>
        <% if (ticket.createdBy.company) { %>
        <div class="info-item">
          <span class="info-label">Empresa</span>
          <span class="info-value"><%= ticket.createdBy.company %></span>
        </div>
        <% } %>
        <div class="info-item">
          <span class="info-label">Abertura</span>
          <span class="info-value"><%= new Date(ticket.createdAt).toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Tempo decorrido</span>
          <span class="info-value"><%= ticket.timeElapsed %></span>
        </div>
        <% if (ticket.resolvedAt) { %>
        <div class="info-item">
          <span class="info-label">Resolvido em</span>
          <span class="info-value text-success"><%= ticket.resolutionTime %></span>
        </div>
        <% } %>
        <% if (ticket.rating && ticket.rating.score) { %>
        <div class="info-item">
          <span class="info-label">Avaliação</span>
          <span class="info-value">
            <% for (let i = 1; i <= 5; i++) { %>
            <i class="fas fa-star" style="color: <%= i <= ticket.rating.score ? '#f59e0b' : '#334155' %>; font-size: 12px"></i>
            <% } %>
          </span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- History -->
    <% if (ticket.history && ticket.history.length > 0) { %>
    <div class="ts-card">
      <h4><i class="fas fa-history"></i> Histórico</h4>
      <div class="history-list">
        <% ticket.history.slice().reverse().slice(0, 8).forEach(h => { %>
        <div class="history-item">
          <div class="history-dot"></div>
          <div class="history-content">
            <span class="history-note"><%= h.note || h.action %></span>
            <% if (h.performedBy) { %>
            <small class="history-by">por <%= h.performedBy.name %></small>
            <% } %>
            <small class="history-time"><%= new Date(h.createdAt).toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) %></small>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<!-- Rate Modal -->
<% if (user.role === 'client') { %>
<div id="rateModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal-card">
    <div class="modal-header">
      <h3><i class="fas fa-star"></i> Avaliar Atendimento</h3>
      <button onclick="document.getElementById('rateModal').style.display='none'" class="modal-close">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form action="/tickets/<%= ticket._id %>/rate" method="POST">
      <div class="modal-body">
        <div class="star-rating">
          <% for (let i = 5; i >= 1; i--) { %>
          <input type="radio" name="score" id="star<%= i %>" value="<%= i %>" required>
          <label for="star<%= i %>"><i class="fas fa-star"></i></label>
          <% } %>
        </div>
        <div class="form-group">
          <label>Comentário (opcional)</label>
          <textarea name="comment" class="form-control" rows="3" placeholder="Como foi o atendimento?"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('rateModal').style.display='none'" class="btn btn-ghost">
          Cancelar
        </button>
        <button type="submit" class="btn btn-primary">
          <i class="fas fa-paper-plane"></i> Enviar avaliação
        </button>
      </div>
    </form>
  </div>
</div>
<% } %>

<script>
function setReplyType(type) {
  document.getElementById('commentType').value = type;
  document.getElementById('publicBtn').classList.toggle('active', type === 'public');
  document.getElementById('internalBtn').classList.toggle('active', type === 'internal');
  const textarea = document.querySelector('.reply-textarea');
  if (type === 'internal') {
    textarea.placeholder = '📝 Nota interna — visível apenas para agentes e admins...';
    textarea.style.borderColor = '#f59e0b';
  } else {
    textarea.placeholder = 'Digite sua resposta...';
    textarea.style.borderColor = '';
  }
}
</script>
